        self.u=self.entry("Username",25); self.p=self.entry("Password",10,show="*")
        tk.Button(self.w,text="Login",command=self.check,bg="darkgreen",fg="white",font=("Arial",10,"bold"),width=22).pack(pady=22)
    def entry(self,label,pady,show=None):
        tk.Label(self.w,text=label).pack(pady=(pady,5)); e=tk.Entry(self.w,width=32,show=show); e.pack(); return e
    def check(self):
        u,p=self.u.get().strip(), self.p.get().strip()
        if u in USERS and USERS[u][0]==p: self.w.destroy(); self.ok(USERS[u][1])
        else: messagebox.showerror("Error","Invalid Login")
class FormSection:
    def __init__(self, parent, sys, refresh, role, kind):
        self.sys,self.refresh,self.role,self.kind=sys,refresh,role,kind; self.make(parent)
    def make(self,parent):
        isd=self.kind=="donor"; title_txt="Donor Management" if isd else "Recipient Management"
        f=tk.LabelFrame(parent,text=title_txt,font=("Arial",12,"bold")); f.pack(fill="x",padx=10,pady=10)
        labels=["ID","Name","Age","Gender","Blood Group","Organ" if isd else "Organ Needed","Status"] if isd else ["ID","Name","Age","Gender","Blood Group","Organ Needed","Priority","Status"]
        vals={"Gender":GENDERS,"Blood Group":BG,"Organ":ORGANS,"Organ Needed":ORGANS,"Priority":PRIORITIES,"Status":["Available","Matched"] if isd else ["Waiting","Matched"]}
        self.w={}
        for i,l in enumerate(labels):
            tk.Label(f,text=l+":").grid(row=i//4,column=(i%4)*2,sticky="w",padx=5,pady=5)
            w=ttk.Combobox(f,values=vals[l],state="readonly" if l in vals and l!="Organ" and l!="Organ Needed" else "normal",width=15) if l in vals else tk.Entry(f,width=18)
            w.grid(row=i//4,column=(i%4)*2+1,padx=5,pady=5); self.w[l]=w
        self.w["Status"].set("Available" if isd else "Waiting")
        if not isd: self.w["Priority"].set("Normal")
        bf=tk.Frame(f); bf.grid(row=2,column=0,columnspan=8,pady=10)
        for text,cmd,bg in [("Add",self.add,"green"),("Update",self.update,"blue"),("Search",self.search,"purple"),("Delete",self.delete,"red"),("Clear",self.clear,"orange")]:
            b=tk.Button(bf,text=f"{text} {'Donor' if isd else 'Recipient'}" if text!="Clear" else text,command=cmd,bg=bg,fg="white",width=15)
            b.pack(side="left",padx=4)
            if self.role=="Doctor" and text in ["Add","Update","Delete"]: b.config(state="disabled")
    def g(self,k): return self.w[k].get()
    def obj(self):
        organ_key = "Organ" if self.kind=="donor" else "Organ Needed"
        ok,msg=self.sys.valid(self.g("ID"),self.g("Name"),self.g("Age"),self.g("Gender"),self.g("Blood Group"),self.g(organ_key))
        if not ok: messagebox.showerror("Error",msg); return None
        return Donor(self.g("ID"),self.g("Name"),self.g("Age"),self.g("Gender"),self.g("Blood Group"),self.g("Organ"),self.g("Status")) if self.kind=="donor" else Recipient(self.g("ID"),self.g("Name"),self.g("Age"),self.g("Gender"),self.g("Blood Group"),self.g("Organ Needed"),self.g("Priority"),self.g("Status"))
    def add(self):
        o=self.obj()
        if o and (self.sys.add_donor(o) if self.kind=="donor" else self.sys.add_recipient(o)): messagebox.showinfo("Success","Record added."); self.clear(); self.refresh()
        elif o: messagebox.showerror("Error","ID already exists.")
    def update(self):
        o=self.obj()
        if o and (self.sys.update_donor(o) if self.kind=="donor" else self.sys.update_recipient(o)): messagebox.showinfo("Success","Record updated."); self.refresh()
        elif o: messagebox.showerror("Error","Record not found.")
    def search(self):
        o=(self.sys.search_donor(self.g("ID")) if self.kind=="donor" else self.sys.search_recipient(self.g("ID")))
        if not o: messagebox.showerror("Error","Record not found."); return
        self.clear(); self.w["ID"].insert(0,o.pid); self.w["Name"].insert(0,o.name); self.w["Age"].insert(0,o.age); self.w["Gender"].set(o.gender); self.w["Blood Group"].set(o.blood_group)
        if self.kind=="donor": self.w["Organ"].set(o.organ); self.w["Status"].set(o.status)
        else: self.w["Organ Needed"].set(o.organ_needed); self.w["Priority"].set(o.priority); self.w["Status"].set(o.status)
    def delete(self):
        if self.sys.delete(self.kind,self.g("ID")): messagebox.showinfo("Success","Record deleted."); self.clear(); self.refresh()
        else: messagebox.showerror("Error","Record not found.")
    def clear(self):
        for k,w in self.w.items():
            if isinstance(w, tk.Entry): w.delete(0,tk.END)
            else: w.set("")
        self.w["Status"].set("Available" if self.kind=="donor" else "Waiting")
        if self.kind!="donor": self.w["Priority"].set("Normal")
class Matching:
    def __init__(self,parent,sys,refresh):
        self.sys,self.refresh=sys,refresh; f=tk.LabelFrame(parent,text="Organ Matching",font=("Arial",12,"bold")); f.pack(fill="both",expand=True,padx=10,pady=10)
        bf=tk.Frame(f); bf.pack(fill="x",pady=10)
        for t,c,b in [("Find Best Matches",self.match,"blue"),("Reset Statuses",self.reset,"red"),("Clear Results",lambda:self.text.delete("1.0",tk.END),"orange")]:
            tk.Button(bf,text=t,command=c,bg=b,fg="white",font=("Arial",11,"bold")).pack(side="left",padx=5)
        self.text=tk.Text(f,height=18,width=80); self.text.pack(fill="both",expand=True,padx=5,pady=5)
    def match(self):
        c=self.sys.match_organs(); self.show(); messagebox.showinfo("Matching Results",f"{c} organ match(es) found."); self.refresh()
    def reset(self):
        if messagebox.askyesno("Confirm","Reset all donor and recipient statuses?"): self.sys.reset(); self.refresh(); self.show()
    def show(self):
        self.text.delete("1.0",tk.END)
        self.text.insert(tk.END,"=== MATCHING RESULTS ===\n\nScoring: Organ 50 + Blood 30 + Priority up to 20 + Age up to 10\n\n")
        self.text.insert(tk.END,"\n".join(f"{i}. {m}" for i,m in enumerate(self.sys.matches,1)) or "No new matches found.")
class History:
    def __init__(self,parent,sys):
        self.sys=sys; f=tk.LabelFrame(parent,text="Activity and Match History",font=("Arial",12,"bold")); f.pack(fill="both",expand=True,padx=10,pady=10)
        bf=tk.Frame(f); bf.pack(fill="x",pady=10)
        tk.Button(bf,text="Refresh History",command=self.refresh_history,bg="blue",fg="white").pack(side="left",padx=5)
        tk.Button(bf,text="Export Match CSV",command=self.export,bg="teal",fg="white").pack(side="left",padx=5)
        self.text=tk.Text(f,height=22,width=90); self.text.pack(fill="both",expand=True,padx=5,pady=5)
    def refresh_history(self):
        self.text.delete("1.0",tk.END); self.text.insert(tk.END,"=== MATCH HISTORY ===\n\n")
        ms=self.sys.db.matches()
        self.text.insert(tk.END, "\n".join(f"{m[9]}: {m[1]} ({m[5]}) → {m[3]} ({m[6]}) | {m[4]} | Priority: {m[7]} | Score: {m[8]}" for m in ms) or "No match history available.")
        self.text.insert(tk.END,"\n\n=== ACTIVITY LOG ===\n\n" + ("\n".join(self.sys.history[:100]) or "No activity history available."))
    def export(self):
        ms=self.sys.db.matches()
        if not ms: messagebox.showwarning("No Data","No matches to export."); return
        p=filedialog.asksaveasfilename(defaultextension=".csv",filetypes=[("CSV files","*.csv")],initialfile=f"matches_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv")
        if p:
            with open(p,"w",newline="") as f:
                w=csv.writer(f); w.writerow(["Donor ID","Donor Name","Recipient ID","Recipient Name","Organ","Donor Blood","Recipient Blood","Priority","Score","Date"]); w.writerows(ms)
            messagebox.showinfo("Success",f"Match history exported to {p}")
