        stats = f"""
=== SYSTEM STATISTICS ===
Total Donors: {self.system.donor_count()}
Total Recipients: {self.system.recipient_count()}
Total Matches: {self.system.match_count()}
Blood Group Distribution:
"""
        self.stats_text.insert(tk.END, stats)
        blood_groups = self.system.get_blood_group_stats()
        for bg, count in sorted(blood_groups.items()):
            self.stats_text.insert(tk.END, f"  {bg}: {count}\n")
    def show_blood_group_chart(self):
        blood_groups = self.system.get_blood_group_stats()
        if not blood_groups or sum(blood_groups.values()) == 0:
            messagebox.showwarning("No Data", "No donor data available for chart")
            return
        labels = list(blood_groups.keys())
        sizes = list(blood_groups.values())
        colors_list = ['#ff9999', '#66b3ff', '#99ff99', '#ffcc99', '#ff99cc', '#c2c2f0', '#ffb3e6', '#c2f0c2']
        plt.figure(figsize=(10, 8))
        plt.pie(sizes, labels=labels, colors=colors_list[:len(labels)], autopct='%1.1f%%',
                startangle=90, textprops={'fontsize': 12, 'weight': 'bold'})
        plt.title("Blood Group Distribution Among Donors", fontsize=14, weight='bold', pad=20)
        plt.axis('equal')
        plt.tight_layout()
        plt.show()
    def export_donors_csv(self):
        if not self.system.donors:
            messagebox.showwarning("No Data", "No donors to export")
            return
        file_path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=[("CSV files", "*.csv"), ("All files", "*.*")],
            initialfile=f"donors_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        )
        if file_path:
            try:
                with open(file_path, 'w', newline='') as csvfile:
                    fieldnames = ['ID', 'Name', 'Age', 'Gender', 'Blood Group', 'Organ', 'Status', 'Date']
                    writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                    writer.writeheader()  
                    for donor in self.system.donors:
                        writer.writerow({
                            'ID': donor.pid,
                            'Name': donor.name,
                            'Age': donor.age,
                            'Gender': donor.gender,
                            'Blood Group': donor.blood_group,
                            'Organ': donor.organ,
                            'Status': donor.status,
                            'Date': donor.date
                        })               
                messagebox.showinfo("Success", f"Donors exported to {file_path}")
            except Exception as e:
                messagebox.showerror("Error", f"Failed to export: {str(e)}")
    def export_recipients_csv(self):
        if not self.system.recipients:
            messagebox.showwarning("No Data", "No recipients to export")
            return
        file_path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=[("CSV files", "*.csv"), ("All files", "*.*")],
            initialfile=f"recipients_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        )
        if file_path:
            try:
                with open(file_path, 'w', newline='') as csvfile:
                    fieldnames = ['ID', 'Name', 'Age', 'Gender', 'Blood Group', 'Organ Needed', 'Priority', 'Date']
                    writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
                    writer.writeheader()                  
                    for recipient in self.system.recipients:
                        writer.writerow({
                            'ID': recipient.pid,
                            'Name': recipient.name,
                            'Age': recipient.age,
                            'Gender': recipient.gender,
                            'Blood Group': recipient.blood_group,
                            'Organ Needed': recipient.organ_needed,
                            'Priority': recipient.priority,
                            'Date': recipient.date
                        })               
                messagebox.showinfo("Success", f"Recipients exported to {file_path}")
            except Exception as e:
                messagebox.showerror("Error", f"Failed to export: {str(e)}")
