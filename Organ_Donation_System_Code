class OrganDonationGUI:
    def __init__(self, root):
        self.root = root
        self.root.title("MediCare - Organ Donation System")
        self.root.geometry("1400x900")
        self.root.config(bg="lightblue")
        header_frame = tk.Frame(root, bg="darkgreen", height=60)
        header_frame.pack(fill="x")
    
        header_title = tk.Label(header_frame, text="MediCare - Hospital Organ Donation Management System", 
                               font=("Arial", 18, "bold"), bg="darkgreen", fg="white")
        header_title.pack(pady=10)
        self.system = OrganDonationSystem()
        self.notebook = ttk.Notebook(root)
        self.notebook.pack(fill="both", expand=True, padx=5, pady=5)
        self.donor_tab = ttk.Frame(self.notebook)
        self.rec_tab = ttk.Frame(self.notebook)
        self.match_tab = ttk.Frame(self.notebook)
        self.history_tab = ttk.Frame(self.notebook)
        self.analytics_tab = ttk.Frame(self.notebook)
        self.notebook.add(self.donor_tab, text="Donors")
        self.notebook.add(self.rec_tab, text="Recipients")
        self.notebook.add(self.match_tab, text="Matching")
        self.notebook.add(self.history_tab, text="History")
        self.notebook.add(self.analytics_tab, text="Analytics")
        self.donor_section = DonorSection(self.donor_tab, self.system, self.refresh_table)
        self.recipient_section = RecipientSection(self.rec_tab, self.system, self.refresh_table)
        self.matching_section = MatchingSection(self.match_tab, self.system, self.refresh_table)
        self.history_section = HistorySection(self.history_tab, self.system)
        self.analytics_section = AnalyticsSection(self.analytics_tab, self.system)
        self.create_table()
    def create_table(self):
        table_frame = tk.LabelFrame(self.root, text="All Records", font=("Arial", 12, "bold"))
        table_frame.pack(fill="both", expand=True, padx=10, pady=10)
        self.tree = ttk.Treeview(table_frame, columns=("ID", "Name", "Type", "Organ", "Blood"), show="headings", height=10)
        for c in ("ID", "Name", "Type", "Organ", "Blood"):
            self.tree.heading(c, text=c)
            self.tree.column(c, width=200)
        scrollbar = ttk.Scrollbar(table_frame, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscroll=scrollbar.set)
        self.tree.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
    def refresh_table(self):
        self.tree.delete(*self.tree.get_children())
        for d in self.system.donors:
            self.tree.insert("", "end", values=(d.pid, d.name, "Donor", d.organ, d.blood_group))
        for r in self.system.recipients:
            self.tree.insert("", "end", values=(r.pid, r.name, "Recipient", r.organ_needed, r.blood_group))
        self.history_section.refresh_history()
def start():
    root = tk.Tk()
    OrganDonationGUI(root)
    root.mainloop()
if __name__ == "__main__":
    root = tk.Tk()
    root.withdraw()
    LoginWindow(root, start)
    root.mainloop()
