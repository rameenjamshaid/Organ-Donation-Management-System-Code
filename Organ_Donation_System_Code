class Database:
    def __init__(self):
        self.conn = sqlite3.connect("hospital.db")
        self.cursor = self.conn.cursor()
        self.create_tables()
    def create_tables(self):
        self.cursor.execute("""
        CREATE TABLE IF NOT EXISTS donors(
            id TEXT PRIMARY KEY,
            name TEXT,
            age INTEGER,
            gender TEXT,
            blood_group TEXT,
            organ TEXT,
            status TEXT,
            date TEXT
        )
        """)
        self.cursor.execute("""
        CREATE TABLE IF NOT EXISTS recipients(
            id TEXT PRIMARY KEY,
            name TEXT,
            age INTEGER,
            gender TEXT,
            blood_group TEXT,
            organ_needed TEXT,
            priority TEXT,
            date TEXT
        )
        """)
        self.conn.commit()
    def get_all_donors(self):
        self.cursor.execute("SELECT * FROM donors")
        return self.cursor.fetchall()
    def get_all_recipients(self):
        self.cursor.execute("SELECT * FROM recipients")
        return self.cursor.fetchall()
class Person:
    def __init__(self, pid, name, age, gender, blood_group):
        self.pid = pid
        self.name = name
        self.age = int(age)
        self.gender = gender
        self.blood_group = blood_group
class Donor(Person):
    def __init__(self, pid, name, age, gender, blood_group, organ, status="Available"):
        super().__init__(pid, name, age, gender, blood_group)
        self.organ = organ
        self.status = status
        self.date = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    def to_tuple(self):
        return (self.pid, self.name, self.age, self.gender,
                self.blood_group, self.organ,
                self.status, self.date)
class Recipient(Person):
    def __init__(self, pid, name, age, gender, blood_group, organ_needed, priority="Normal"):
        super().__init__(pid, name, age, gender, blood_group)
        self.organ_needed = organ_needed
        self.priority = priority
        self.date = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    def to_tuple(self):
        return (self.pid, self.name, self.age, self.gender,
                self.blood_group, self.organ_needed,
                self.priority, self.date)
class OrganDonationSystem:
    def __init__(self):
        self.db = Database()
        self.donors = []
        self.recipients = []
        self.matches = []
        self.history = []
    def log(self, action):
        time = datetime.now().strftime("%H:%M:%S")
        self.history.append(f"{time} - {action}")
    def add_donor(self, donor):
        if self.search_donor(donor.pid):
            return False
        self.donors.append(donor)
        self.db.cursor.execute("INSERT INTO donors VALUES (?,?,?,?,?,?,?,?)",
                               donor.to_tuple())
        self.db.conn.commit()
        self.log(f"Added Donor {donor.name}")
        return True
    def add_recipient(self, rec):
        if self.search_recipient(rec.pid):
            return False
        self.recipients.append(rec)
        self.db.cursor.execute("INSERT INTO recipients VALUES (?,?,?,?,?,?,?,?)",
                               rec.to_tuple())
        self.db.conn.commit()
        self.log(f"Added Recipient {rec.name}")
        return True
    def search_donor(self, pid):
        return next((d for d in self.donors if d.pid == pid), None)
    def search_recipient(self, pid):
        return next((r for r in self.recipients if r.pid == pid), None)
    def delete_donor(self, pid):
        d = self.search_donor(pid)
        if not d:
            return False
        self.donors.remove(d)
        self.db.cursor.execute("DELETE FROM donors WHERE id=?", (pid,))
        self.db.conn.commit()
        self.log(f"Deleted Donor {pid}")
        return True
    def delete_recipient(self, pid):
        r = self.search_recipient(pid)
        if not r:
            return False
        self.recipients.remove(r)
        self.db.cursor.execute("DELETE FROM recipients WHERE id=?", (pid,))
        self.db.conn.commit()
        self.log(f"Deleted Recipient {pid}")
        return True
    def match_organs(self):
        self.matches.clear()
        for d in self.donors:
            if d.status != "Available":
                continue
            for r in self.recipients:
                if (d.organ.lower() == r.organ_needed.lower() and
                        d.blood_group == r.blood_group):
                    d.status = "Matched"
                    self.matches.append(f"{d.name} → {r.name} ({d.organ})")
                    self.log(f"Match {d.name} with {r.name}")
        return len(self.matches)
    def get_blood_group_stats(self):
        blood_groups = {}
        for d in self.donors:
            blood_groups[d.blood_group] = blood_groups.get(d.blood_group, 0) + 1
        for r in self.recipients:
            if r.blood_group not in blood_groups:
                blood_groups[r.blood_group] = 0
        return blood_groups
    def donor_count(self): 
        return len(self.donors)
    def recipient_count(self): 
        return len(self.recipients)
    def match_count(self): 
        return len(self.matches)
