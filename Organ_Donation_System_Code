def now(): return datetime.now().strftime("%Y-%m-%d %H:%M:%S")
def title(s): return str(s).strip().title()
class DBM:
    def __init__(self):
        self.con = sqlite3.connect(DB); self.cur = self.con.cursor(); self.init()
    def init(self):
        self.cur.execute("""CREATE TABLE IF NOT EXISTS donors(
            id TEXT PRIMARY KEY,name TEXT,age INTEGER,gender TEXT,blood_group TEXT,organ TEXT,status TEXT,date TEXT)""")
        self.cur.execute("""CREATE TABLE IF NOT EXISTS recipients(
            id TEXT PRIMARY KEY,name TEXT,age INTEGER,gender TEXT,blood_group TEXT,organ_needed TEXT,
            priority TEXT,status TEXT DEFAULT 'Waiting',date TEXT)""")
        self.cur.execute("""CREATE TABLE IF NOT EXISTS match_history(
            id INTEGER PRIMARY KEY AUTOINCREMENT,donor_id TEXT,donor_name TEXT,recipient_id TEXT,recipient_name TEXT,
            organ TEXT,donor_blood TEXT,recipient_blood TEXT,priority TEXT,score INTEGER,date TEXT)""")
        self.cur.execute("""CREATE TABLE IF NOT EXISTS activity_log(
            id INTEGER PRIMARY KEY AUTOINCREMENT,action TEXT,date TEXT)""")
        self.con.commit()
        cols = [x[1] for x in self.cur.execute("PRAGMA table_info(recipients)")]
        if "status" not in cols:
            self.cur.execute("ALTER TABLE recipients ADD COLUMN status TEXT DEFAULT 'Waiting'"); self.con.commit()
    def all(self, table, fields="*"):
        return self.cur.execute(f"SELECT {fields} FROM {table} ORDER BY date DESC").fetchall()
    def matches(self):
        return self.cur.execute("""SELECT donor_id,donor_name,recipient_id,recipient_name,organ,donor_blood,
            recipient_blood,priority,score,date FROM match_history ORDER BY id DESC""").fetchall()
    def logs(self): return self.cur.execute("SELECT action,date FROM activity_log ORDER BY id DESC").fetchall()
    def exec(self, q, args=()): self.cur.execute(q, args); self.con.commit()
class Person:
    def __init__(self, pid, name, age, gender, blood):
        self.pid, self.name, self.age, self.gender, self.blood_group = str(pid).strip(), str(name).strip(), int(age), gender, blood
class Donor(Person):
    def __init__(self, pid, name, age, gender, blood, organ, status="Available", date=None):
        super().__init__(pid, name, age, gender, blood); self.organ, self.status, self.date = title(organ), status, date or now()
    def row(self): return (self.pid,self.name,self.age,self.gender,self.blood_group,self.organ,self.status,self.date)
class Recipient(Person):
    def __init__(self, pid, name, age, gender, blood, organ, priority="Normal", status="Waiting", date=None):
        super().__init__(pid, name, age, gender, blood); self.organ_needed, self.priority, self.status, self.date = title(organ), priority, status, date or now()
    def row(self): return (self.pid,self.name,self.age,self.gender,self.blood_group,self.organ_needed,self.priority,self.status,self.date)
class System:
    def __init__(self): self.db=DBM(); self.donors=[]; self.recipients=[]; self.matches=[]; self.history=[]; self.load()
    def load(self):
        self.donors = [Donor(*r) for r in self.db.all("donors","id,name,age,gender,blood_group,organ,status,date")]
        self.recipients = [Recipient(*r) for r in self.db.all("recipients","id,name,age,gender,blood_group,organ_needed,priority,status,date")]
        self.history = [f"{d} - {a}" for a,d in self.db.logs()]
    def log(self, a): self.history.insert(0, f"{now()} - {a}"); self.db.exec("INSERT INTO activity_log(action,date) VALUES(?,?)",(a,now()))
    def valid(self, pid,name,age,gender,blood,organ):
        if not all([pid,name,age,gender,blood,organ]): return False, "Please fill all fields."
        try: age=int(age)
        except: return False, "Age must be a number."
        if not 1 <= age <= 120: return False, "Age must be between 1 and 120."
        if gender not in GENDERS or blood not in BG: return False, "Select valid gender and blood group."
        return True, ""
    def find(self, arr, pid): return next((x for x in arr if x.pid == str(pid).strip()), None)
    def search_donor(self,pid): return self.find(self.donors,pid)
    def search_recipient(self,pid): return self.find(self.recipients,pid)
    def add_donor(self,d):
        if self.search_donor(d.pid): return False
        self.donors.append(d); self.db.exec("INSERT INTO donors VALUES(?,?,?,?,?,?,?,?)", d.row()); self.log(f"Added Donor {d.name}"); return True
    def add_recipient(self,r):
        if self.search_recipient(r.pid): return False
        self.recipients.append(r); self.db.exec("INSERT INTO recipients VALUES(?,?,?,?,?,?,?,?,?)", r.row()); self.log(f"Added Recipient {r.name}"); return True
    def update_donor(self,d):
        old=self.search_donor(d.pid)
        if not old: return False
        old.__dict__.update(d.__dict__); self.db.exec("UPDATE donors SET name=?,age=?,gender=?,blood_group=?,organ=?,status=? WHERE id=?", d.row()[1:7]+(d.pid,)); self.log(f"Updated Donor {d.name}"); return True
    def update_recipient(self,r):
        old=self.search_recipient(r.pid)
        if not old: return False
        old.__dict__.update(r.__dict__); self.db.exec("UPDATE recipients SET name=?,age=?,gender=?,blood_group=?,organ_needed=?,priority=?,status=? WHERE id=?", r.row()[1:8]+(r.pid,)); self.log(f"Updated Recipient {r.name}"); return True
    def delete(self, kind, pid):
        arr, table = (self.donors,"donors") if kind=="donor" else (self.recipients,"recipients")
        obj = self.find(arr,pid)
        if not obj: return False
        arr.remove(obj); self.db.exec(f"DELETE FROM {table} WHERE id=?", (pid,)); self.log(f"Deleted {kind.title()} {pid}"); return True
    def score(self,d,r):
        s = (50 if d.organ.lower()==r.organ_needed.lower() else 0) + (30 if r.blood_group in COMPAT.get(d.blood_group,[]) else 0) + PPOINTS.get(r.priority,10)
        diff=abs(d.age-r.age); return min(100, s + (10 if diff<=10 else 5 if diff<=25 else 0))
    def match_organs(self):
        self.matches=[]; used=set()
        for d in [x for x in self.donors if x.status=="Available"]:
            choices=[(self.score(d,r),r) for r in self.recipients if r.status=="Waiting" and r.pid not in used and d.organ.lower()==r.organ_needed.lower() and r.blood_group in COMPAT.get(d.blood_group,[])]
            if not choices: continue
            sc,r=max(choices, key=lambda x:x[0])
            if sc < 60: continue
            d.status="Matched"; r.status="Matched"; used.add(r.pid)
            self.db.exec("UPDATE donors SET status='Matched' WHERE id=?", (d.pid,))
            self.db.exec("UPDATE recipients SET status='Matched' WHERE id=?", (r.pid,))
            self.db.exec("""INSERT INTO match_history(donor_id,donor_name,recipient_id,recipient_name,organ,donor_blood,recipient_blood,priority,score,date)
                       VALUES(?,?,?,?,?,?,?,?,?,?)""", (d.pid,d.name,r.pid,r.name,d.organ,d.blood_group,r.blood_group,r.priority,sc,now()))
            self.matches.append(f"{d.name} → {r.name} | {d.organ} | Score: {sc}"); self.log(f"Matched {d.name} with {r.name}, score {sc}")
        return len(self.matches)
    def reset(self):
        for d in self.donors: d.status="Available"
        for r in self.recipients: r.status="Waiting"
        self.db.exec("UPDATE donors SET status='Available'"); self.db.exec("UPDATE recipients SET status='Waiting'"); self.matches=[]; self.log("Reset all statuses")
    def cnt(self, arr, attr): return dict(Counter(getattr(x, attr) for x in arr))
    def donor_count(self): return len(self.donors)
    def recipient_count(self): return len(self.recipients)
    def match_count(self): return len(self.db.matches())
    def available_donor_count(self): return sum(d.status=="Available" for d in self.donors)
    def waiting_recipient_count(self): return sum(r.status=="Waiting" for r in self.recipients)
class Login:
    def __init__(self, root, ok):
        self.root, self.ok = root, ok; self.w=tk.Toplevel(root); self.w.title("Login"); self.w.geometry("420x330"); self.w.resizable(False,False)
        tk.Label(self.w,text="MediCare",font=("Arial",24,"bold"),fg="darkgreen").pack(pady=10)
